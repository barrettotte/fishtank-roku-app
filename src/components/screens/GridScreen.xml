<?xml version="1.0" encoding="utf-8" ?>
<!-- Camera grid screen showing all available streams -->
<component name="GridScreen" extends="Group">

  <interface>
    <!-- Fires when a camera is selected. Value is the stream content node -->
    <field id="streamSelected" type="node" alwaysNotify="true" />
  </interface>

  <script type="text/brightscript" uri="GridScreen.bs" />
  <script type="text/brightscript" uri="pkg:/source/utils/constants.bs" />
  <script type="text/brightscript" uri="pkg:/source/utils/auth.bs" />

  <children>
    <!-- Dark background -->
    <Rectangle id="background" width="1920" height="1080" color="0x191C20FF" />

    <!-- Header bar -->
    <Rectangle id="headerBar" width="1920" height="80" color="0x191C20FF" />
    <Poster id="headerLogo"
      uri="pkg:/images/logo-stripe.png"
      width="200"
      height="40"
      translation="[40, 20]"
      loadDisplayMode="scaleToFit" />

    <!-- Status: username + online count + date/time (right-aligned) -->
    <Label id="headerStatus"
      text="Loading..."
      width="1600"
      translation="[280, 0]"
      height="80"
      vertAlign="center"
      horizAlign="right"
      font="font:SmallSystemFont"
      color="0x999999FF" />

    <!-- Camera grid -->
    <MarkupGrid id="cameraGrid"
      translation="[40, 100]"
      numColumns="5"
      numRows="4"
      itemSize="[356, 245]"
      itemSpacing="[10, 10]"
      drawFocusFeedback="true"
      focusBitmapBlendColor="0xDF4E1EFF"
      itemComponentName="CameraGridItem" />

    <!-- Loading/error message -->
    <Label id="messageLabel"
      text="Loading streams..."
      width="1920"
      height="1080"
      translation="[0, 0]"
      horizAlign="center"
      vertAlign="center"
      font="font:MediumSystemFont"
      color="0xDDDEC4FF" />
  </children>

</component>
