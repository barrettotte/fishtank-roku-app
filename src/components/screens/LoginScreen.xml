<?xml version="1.0" encoding="utf-8" ?>
<!-- Login screen with email/password input using keyboard dialogs -->
<component name="LoginScreen" extends="Group">

  <interface>
    <!-- Fires when login succeeds. Value is the session assocarray -->
    <field id="loginSuccess" type="assocarray" alwaysNotify="true" />
    <!-- Fires with error message string on login failure -->
    <field id="loginError" type="string" alwaysNotify="true" />
  </interface>

  <script type="text/brightscript" uri="LoginScreen.bs" />
  <script type="text/brightscript" uri="pkg:/source/utils/constants.bs" />
  <script type="text/brightscript" uri="pkg:/source/utils/registry.bs" />

  <children>
    <!-- Dark background -->
    <Rectangle id="background" width="1920" height="1080" color="0x191C20FF" />

    <!-- Logo -->
    <Poster id="logoImage"
      uri="pkg:/images/logo-stripe.png"
      width="560"
      height="112"
      translation="[680, 280]"
      loadDisplayMode="scaleToFit" />

    <!-- Season tag -->
    <Label id="seasonLabel"
      text="Season 5"
      width="1920"
      translation="[0, 410]"
      horizAlign="center"
      font="font:SmallSystemFont"
      color="0x999999FF" />

    <!-- Prompt text -->
    <Label id="promptLabel"
      text="Press OK to log in"
      width="1920"
      translation="[0, 480]"
      horizAlign="center"
      font="font:MediumSystemFont"
      color="0xFFFFFFFF" />

    <!-- Status text for errors/loading -->
    <Label id="statusLabel"
      text=""
      width="1920"
      translation="[0, 540]"
      horizAlign="center"
      font="font:SmallSystemFont"
      color="0xEFC820FF" />

    <!-- "Log In" button -->
    <Rectangle id="loginButtonBg"
      width="400"
      height="60"
      translation="[760, 610]"
      color="0x26B64BFF" />
    <Label id="loginButtonLabel"
      text="Log In"
      width="400"
      height="60"
      translation="[760, 610]"
      horizAlign="center"
      vertAlign="center"
      font="font:MediumBoldSystemFont"
      color="0xFFFFFFFF" />

    <!-- Credits -->
    <Label id="versionLabel"
      text=""
      width="1920"
      translation="[0, 730]"
      horizAlign="center"
      font="font:SmallestSystemFont"
      color="0x999999FF" />
    <Label id="repoLabel"
      text="github.com/barrettotte/fishtank-roku-app"
      width="1920"
      translation="[0, 758]"
      horizAlign="center"
      font="font:SmallestSystemFont"
      color="0x999999FF" />

  </children>

</component>
