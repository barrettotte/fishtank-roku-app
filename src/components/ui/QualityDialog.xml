<?xml version="1.0" encoding="utf-8" ?>
<!-- Settings dialog for stream quality and server selection -->
<component name="QualityDialog" extends="Group">

  <interface>
    <!-- Output: fires with the selected quality value -->
    <field id="selectedQuality" type="string" alwaysNotify="true" />
    <!-- Output: fires with the selected server hostname -->
    <field id="selectedServer" type="string" alwaysNotify="true" />
    <!-- Output: fires when the dialog is dismissed -->
    <field id="close" type="boolean" alwaysNotify="true" />
    <!-- Function: sets the initial state -->
    <function name="setCurrentSettings" />
  </interface>

  <script type="text/brightscript" uri="QualityDialog.bs" />
  <script type="text/brightscript" uri="pkg:/source/utils/constants.bs" />

  <children>
    <!-- Semi-transparent backdrop -->
    <Rectangle id="backdrop" width="1920" height="1080" color="0x00000088" />

    <!-- Dialog panel (sized dynamically in init) -->
    <Rectangle id="panelBorder" color="0x2A2D32FF" />
    <Rectangle id="panelBg" color="0x191C20FF" />

    <!-- Title -->
    <Label id="titleLabel"
      text="Stream Settings"
      horizAlign="center"
      font="font:SmallBoldSystemFont"
      color="0xFFFFFFFF" />

    <!-- Container for dynamically created options -->
    <Group id="optionsContainer" />
  </children>

</component>
